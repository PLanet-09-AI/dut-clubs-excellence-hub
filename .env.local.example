# ─── Email Reminders Configuration ────────────────────────────────────────
# Required for sending reminder emails to users with incomplete nominations

# Your EmailJS Public Key (from emailjs.com Account → API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (from emailjs.com Email Services)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (from emailjs.com Email Templates)
# Template should have variables: to_email, nominator_name, nominee_name, 
# category_name, incomplete_items, submission_url, current_year
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Your EmailJS Private Key (for Netlify Functions - Server-side only)
# ⚠️  DO NOT commit this to version control!
# Store in Netlify environment variables: Site Settings → Build & Deploy → Environment
EMAILJS_PRIVATE_KEY=your_private_key_here
