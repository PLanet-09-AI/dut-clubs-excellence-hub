# Firebase Environment Variables (example)
# Copy this to .env and fill in your actual values from the Firebase Console

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Office-to-PDF conversion is handled by the Netlify function (netlify/functions/office-to-pdf.mts).
# No API key required — conversion runs locally using mammoth + xlsx + chromium.
